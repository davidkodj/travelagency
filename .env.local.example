# Supabase - récupérez ces valeurs dans votre dashboard Supabase > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-cle-anon-publique
SUPABASE_SERVICE_ROLE_KEY=votre-cle-service-role-PRIVEE

# Resend - créez un compte sur resend.com et générez une clé API
RESEND_API_KEY=re_votre_cle_resend
FROM_EMAIL=noreply@votredomaine.com

# WhatsApp - votre numéro avec indicatif pays, sans le +
NEXT_PUBLIC_WHATSAPP_NUMBER=22890000000

# URL publique du site (sans slash final)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics (optionnel - ajoutez après déploiement)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
